{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / VictoriaMetrics",
      "description": "Prometheus-compatible datasource scraping /api/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Screeps private server — metrics from screepsmod-prometheus",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["screeps"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(screeps_tick_game_time, job)",
        "hide": 0,
        "includeAll": false,
        "label": "Job",
        "multi": false,
        "name": "job",
        "options": [],
        "query": {
          "query": "label_values(screeps_tick_game_time, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(screeps_user_cpu_limit{job=~\"$job\"}, username)",
        "hide": 0,
        "includeAll": true,
        "label": "Player",
        "multi": true,
        "name": "player",
        "options": [],
        "query": {
          "query": "label_values(screeps_user_cpu_limit{job=~\"$job\"}, username)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Screeps Server",
  "uid": "screeps-server-v1",
  "version": 1,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Avg Tick Duration",
      "gridPos": { "x": 0, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_tick_time_ms_sum{job=~\"$job\"}[$__rate_interval]) / rate(screeps_tick_time_ms_count{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "avg tick",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Ticks / min",
      "gridPos": { "x": 5, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_tick_game_time{job=~\"$job\"}[$__rate_interval]) * 60",
          "legendFormat": "ticks/min",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Game Time",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "–",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_tick_game_time{job=~\"$job\"}",
          "legendFormat": "tick",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Active Players",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(screeps_user_cpu_limit{job=~\"$job\"})",
          "legendFormat": "players",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Rooms Processed / s",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_rooms_processed_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "rooms/s",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "Tick Performance",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Tick Duration — P50 / P95 / P99 / avg",
      "description": "Wall-clock time from tick start to finish. P99 > 1600 ms is a sign the server can't keep up.",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, rate(screeps_tick_time_ms_bucket{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(screeps_tick_time_ms_bucket{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, rate(screeps_tick_time_ms_bucket{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "P99",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_tick_time_ms_sum{job=~\"$job\"}[$__rate_interval]) / rate(screeps_tick_time_ms_count{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "avg",
          "refId": "D"
        }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Throughput — Rooms & Users / s",
      "description": "Rate at which rooms and user scripts are queued per second.",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_rooms_processed_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "rooms / s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_users_processed_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "users / s",
          "refId": "B"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Tick Stage Breakdown",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Main-Loop Stage — Avg ms / tick",
      "description": "Average milliseconds spent in each engine main-loop stage per tick. Requires PROM_STAGE_METRICS=true (default on).",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6,
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_tick_stage_ms_sum{job=~\"$job\"}[$__rate_interval]) / rate(screeps_tick_stage_ms_count{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "type": "row",
      "title": "Per-Player Metrics",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 31,
      "type": "timeseries",
      "title": "CPU Usage — ms / s per Player",
      "description": "Rate of cumulative CPU milliseconds (driver usedTime). Roughly: how many ms of player script CPU per second.",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(screeps_user_cpu_ms_total{job=~\"$job\",username=~\"$player\"}[$__rate_interval])",
          "legendFormat": "{{username}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "CPU Bucket Balance per Player",
      "description": "Available CPU bucket credits. Drops toward 0 when a player consistently uses more CPU than their limit.",
      "gridPos": { "x": 8, "y": 23, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "green", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_user_cpu_bucket{job=~\"$job\",username=~\"$player\"}",
          "legendFormat": "{{username}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 33,
      "type": "timeseries",
      "title": "VM Heap Used per Player",
      "description": "IVM isolate heap currently in use. Approaching heapTotal means GC pressure or a memory leak.",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*total.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_user_heap_used_bytes{job=~\"$job\",username=~\"$player\"}",
          "legendFormat": "{{username}} used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_user_heap_total_bytes{job=~\"$job\",username=~\"$player\"}",
          "legendFormat": "{{username}} total",
          "refId": "B"
        }
      ]
    },

    {
      "id": 40,
      "type": "row",
      "title": "Process Memory",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 41,
      "type": "timeseries",
      "title": "Process RSS",
      "description": "Resident set size for each server process (backend, engine_main, engine_runner).",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_process_memory_bytes{job=~\"$job\",type=\"rss\"}",
          "legendFormat": "{{service}} {{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 42,
      "type": "timeseries",
      "title": "Process Heap Used",
      "description": "Node.js V8 heap used vs. total for each server process.",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*heapTotal.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_process_memory_bytes{job=~\"$job\",type=\"heapUsed\"}",
          "legendFormat": "{{service}} {{instance}} heapUsed",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_process_memory_bytes{job=~\"$job\",type=\"heapTotal\"}",
          "legendFormat": "{{service}} {{instance}} heapTotal",
          "refId": "B"
        }
      ]
    },

    {
      "id": 50,
      "type": "row",
      "title": "Custom Player Metrics  (per-player endpoint only)",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 51,
      "type": "timeseries",
      "title": "Game.metrics — Custom Player Gauges",
      "description": "Values published by player scripts via Game.metrics.set(key, value). Only visible on /api/metrics/player (requires Basic Auth). Add a separate Prometheus job that scrapes that endpoint per player.",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6,
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "screeps_custom{username=~\"$player\"}",
          "legendFormat": "{{username}} · {{key}}",
          "refId": "A"
        }
      ]
    }

  ]
}
